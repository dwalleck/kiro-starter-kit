{
  "$schema": "../../agent-schema.json",
  "name": "review-orchestrator",
  "description": "Orchestrates comprehensive PR reviews by coordinating specialized review agents.",
  "prompt": "file://./prompts/review-orchestrator.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "code",
    "glob",
    "use_subagent"
  ],
  "allowedTools": [
    "fs_read",
    "execute_bash",
    "grep",
    "code",
    "glob",
    "use_subagent"
  ],
  "resources": [
    "file://AGENTS.md",
    "skill://.kiro/skills/**/SKILL.md",
    "file://.editorconfig",
    "file://.kiro/steering/*.md"
  ],
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "code-reviewer",
        "code-simplifier",
        "comment-analyzer",
        "pr-test-analyzer",
        "silent-failure-hunter",
        "type-design-analyzer",
        "pci-compliance-reviewer",
        "performance-reviewer"
      ],
      "trustedAgents": [
        "code-reviewer",
        "code-simplifier",
        "comment-analyzer",
        "pr-test-analyzer",
        "silent-failure-hunter",
        "type-design-analyzer",
        "pci-compliance-reviewer",
        "performance-reviewer"
      ]
    }
  }
}
