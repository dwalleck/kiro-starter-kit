{
  "$schema": "../../agent-schema.json",
  "name": "review-orchestrator",
  "description": "Orchestrates comprehensive PR reviews by coordinating specialized review agents.",
  "prompt": "file://./prompts/review-orchestrator.md",
  "model": "claude-opus-4-6",
  "tools": ["fs_read", "fs_write", "execute_bash", "grep", "code", "use_subagent"],
  "resources": [
    "file://AGENTS.md",
    "file://README.md",
    "file://.editorconfig"
  ],
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "code-reviewer",
        "code-simplifier",
        "comment-analyzer",
        "pr-test-analyzer",
        "silent-failure-hunter",
        "type-design-analyzer",
        "pci-compliance-reviewer",
        "performance-reviewer"
      ],
      "trustedAgents": [
        "code-reviewer",
        "code-simplifier",
        "comment-analyzer",
        "pr-test-analyzer",
        "silent-failure-hunter",
        "type-design-analyzer",
        "pci-compliance-reviewer",
        "performance-reviewer"
      ]
    }
  }
}
